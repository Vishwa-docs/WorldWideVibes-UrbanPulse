# UrbanPulse Backend Configuration

# Database (optional — defaults to local SQLite file)
DATABASE_URL=sqlite:///./urbanpulse.db

# Azure OpenAI (optional — falls back to template-based responses without keys)
AZURE_OPENAI_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-2
AZURE_OPENAI_API_VERSION=2024-12-01-preview
LLM_PROVIDER=azure_openai

# Bright Data (optional — uses placeholder signals without keys)
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here
BRIGHTDATA_BASE_URL=https://api.brightdata.com
BRIGHTDATA_SERP_ZONE=serp_api1
BRIGHTDATA_UNLOCKER_ZONE=unlocker1

# Census ACS (optional — used for 31 demographic variables)
CENSUS_API_KEY=your_census_key_here

# Google Places (optional — used for walk score computation)
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Montgomery ArcGIS (no key required — free public REST APIs)
MONTGOMERY_ARCGIS_BASE_URL=https://opendata.montgomeryal.gov

# CORS origins (optional — defaults include localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
